<Window
    x:Class="Velocity.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Velocity Settings"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="620"
            Margin="20"
            Spacing="20">
            <StackPanel Spacing="8">
                <TextBlock
                    FontSize="32"
                    FontWeight="SemiBold"
                    Text="Velocity Settings" />
                <TextBlock x:Name="SubtitleTextBlock" />
                <TextBlock
                    Text="This WinUI 3 sidecar reads and writes the same velocity.yml file used by the Rust background process."
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                Padding="20"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Transcription" />
                    <StackPanel Spacing="6">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <TextBlock Text="Deepgram API key" />
                            <FontIcon
                                FontSize="12"
                                Glyph="&#xE946;"
                                ToolTipService.ToolTip="Log in to the Deepgram Console at https://deepgram.com to generate an API key."
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <PasswordBox x:Name="ApiKeyBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">
                            <TextBlock Text="Model" />
                            <FontIcon
                                FontSize="12"
                                Glyph="&#xE946;"
                                ToolTipService.ToolTip="Only nova-2 and nova-3 are supported Deepgram transcription models right now."
                                VerticalAlignment="Center" />
                        </StackPanel>
                        <ComboBox
                            x:Name="ModelComboBox"
                            SelectionChanged="ModelComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Language" />
                        <ComboBox x:Name="LanguageComboBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Smart formatting" />
                        <ToggleSwitch x:Name="SmartFormatToggle" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recognition key terms" />
                        <TextBlock
                            Opacity="0.75"
                            Text="Enter one word or phrase separated by commas."
                            TextWrapping="WrapWholeWords" />
                        <TextBox
                            x:Name="KeyTermsBox"
                            PlaceholderText="PowerShell, Deepgram, Kubernetes"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Hotkeys" />
                    <StackPanel Spacing="6">
                        <TextBlock Text="Push to talk" />
                        <TextBox x:Name="PushToTalkBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Keep talking" />
                        <TextBox x:Name="KeepTalkingBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Streaming" />
                        <TextBox x:Name="StreamingBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Resend selected transcript" />
                        <TextBox x:Name="ResendBox" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Audio And Output" />
                    <StackPanel Spacing="6">
                        <TextBlock Text="Input device" />
                        <ComboBox
                            x:Name="AudioInputComboBox"
                            SelectionChanged="AudioInputComboBox_SelectionChanged" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Input activity" />
                        <Border
                            x:Name="MicLevelTrack"
                            Height="10"
                            Background="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                            CornerRadius="5"
                            SizeChanged="MicLevelTrack_SizeChanged">
                            <Border
                                x:Name="MicLevelFill"
                                HorizontalAlignment="Left"
                                Background="YellowGreen"
                                CornerRadius="5"
                                Width="0" />
                        </Border>
                        <TextBlock
                            x:Name="MicLevelTextBlock"
                            Text="Waiting for microphone input" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Transcript delivery" />
                        <ComboBox x:Name="OutputModeComboBox" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Recent item retention" />
                        <NumberBox
                            x:Name="HistoryLimitBox"
                            Minimum="1"
                            SpinButtonPlacementMode="Inline" />
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Append newline" />
                        <ToggleSwitch x:Name="AppendNewlineToggle" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Status" />
                    <TextBlock
                        x:Name="ConfigChangedWarningTextBlock"
                        Foreground="DarkOrange"
                        Text="The configuration file changed on disk. Reload before saving to avoid overwriting newer values."
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                    <TextBlock
                        x:Name="StatusTextBlock"
                        Text="Ready"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock x:Name="LaunchModeTextBlock" />
                </StackPanel>
            </Border>

            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    Click="ReloadButton_Click"
                    Content="Reload" />
                <Button
                    Click="SaveButton_Click"
                    Content="Save">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator
                            Invoked="SaveKeyboardAccelerator_Invoked"
                            Key="S"
                            Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
